library(readxl)
read_excel("dados_diversos.xlsx", "fungicida_vaso")
fungicidas <- read_excel("dados_diversos.xlsx", "fungicida_vaso")  #se forem 2 niveis de fator quantitativo                                                          vc trata ela como qualitativa, pois não                                                             existem quantidade de gradiente
View(fungicidas)
Fungicidas2 <-fungicidas |>  mutate(incidencia = inf_seeds/n_seeds)
library(tidyverse)
Fungicidas2 <-fungicidas |>  mutate(incidencia = inf_seeds/n_seeds)
View(Fungicidas2)
library(ggplot2)
fungicidas2 |> ggplot(aes(treat, incidencia))
fungicidas2 <- fungicidas |>
mutate(incidencia = inf_seeds/n_seeds)
fungicidas2 |> ggplot(aes(treat, incidencia))
fungicidas2 |> ggplot(aes(treat, severity))+
geom_jitter()
fungicidas2 |> ggplot(aes(treat, severity))+
geom_jitter(width+0.1)
fungicidas2 |> ggplot(aes(treat, severity))+
geom_jitter(width=0.1)
fungicidas2 |> ggplot(aes(treat, severity), colour=dose)+
geom_jitter(width=0.1)+
```
fungicidas2 |> ggplot(aes(treat, severity), color=dose)+
geom_jitter(width=0.1)+
```
fungicidas2 |> ggplot(aes(treat, severity, color=dose))+
geom_jitter(width=0.1)+
```
fungicidas2 |> ggplot(aes(treat, severity, color = dose))+
geom_jitter(width=0.1)+
```
fungicidas2 |>
mutate(dose= factor=(dose)) |>
fungicidas2 |>
mutate(dose= factor(dose)) |>
ggplot(aes(treat, severity, color = dose))+
geom_jitter(width=0.1)+
```
View(Fungicidas2)
fungicidas2 |>
mutate(dose= factor(dose)) |>
ggplot(aes(treat, severity, color = dose))+
geom_jitter(width=0.1)+
```
fungicidas2 |>
mutate(dose = factor(dose)) |>
ggplot(aes(treat, severity, color = dose))+
geom_jitter(width=0.1)+
facet_wrap(~dose)+
theme(legend.position = "none")
interaction.plot(fungicidas$treat,
fungicidas2$dose, fungicidas$severity)
m1 <- lm(severity ~ treat,
data = fungicidas2)
anova(m1)
m2 <- lm(severity ~ dose,
data = fungicidas2)
anova(m2)
m3 <- lm(severity ~ treat*dose,
data = fungicidas2)
anova(m3)
library(DHARMa)
plot(simulateResiduals(m3))
fungicidas2 <- fungicidas |>
mutate(incidencia = inf_seeds/n_seeds,
dose = factor(dose))
plot(simulateResiduals(m3))
m3 <- lm(severity ~ treat*dose,
data = fungicidas2)
plot(simulateResiduals(m3))
library(emmeans)
medias_m3 <- emmeans (m3, ~ treat|dose)
medias_m3
library(multcomp)
cld(medias_m3, letters=LETTERS)
