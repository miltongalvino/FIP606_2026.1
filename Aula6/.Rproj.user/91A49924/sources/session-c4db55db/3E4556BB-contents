## Carregar o conjunto de dados

```{r}
library(readxl)
library(tidyverse)

fungicidas <- read_excel("dados_diversos.xlsx", "fungicida_vaso")  #se forem 2 niveis de fator quantitativo vc trata ela como qualitativa, pois não existem quantidade de gradiente


fungicidas2 <- fungicidas |> 
  mutate(incidencia = inf_seeds/n_seeds,
         dose = factor(dose))


```

## Visualização de dados

```{r}
library(ggplot2)

fungicidas2 |> 
  mutate(dose = factor(dose)) |> 
  ggplot(aes(treat, severity, color = dose))+
  geom_jitter(width=0.1)+
  facet_wrap(~dose)+
  theme(legend.position = "none")
  
  interaction.plot(fungicidas$treat,
                   fungicidas2$dose, fungicidas$severity)
  
```

```{r}

#verifica individualmente cada 1

m1 <- lm(severity ~ treat, 
         data = fungicidas2)

anova(m1)


m2 <- lm(severity ~ dose, 
         data = fungicidas2)

anova(m2)

m3 <- lm(severity ~ treat*dose, 
         data = fungicidas2)

anova(m3)

#verificar a interação
```

