```{r}
mofo <- read_excel("dados_diversos.xlsx", "mofo")

#Visualizar
mofo |> 
  ggplot(aes(inc, yld))+
  geom_point(width=0.1)+
  geom_smooth(method= "lm", se=F)+
  stat_cor(method = "pearson", label.x = 3, label.y = 30)+
  facet_wrap(~study)



library(ggpubr)
mofo |> 
  ggplot(aes(inc, scl))+
  geom_point(width=0.1)+
  geom_smooth(method= "lm", se=F)+
  stat_cor(method = "pearson", label.x = 3, label.y = 30)+
  facet_wrap(~study)


library(ggplot2)
library(ggpubr)

mofo |> 
  ggplot(aes(inc, scl, color = factor(study))) +
  # Usando geom_jitter para lidar com o width que você deseja
  geom_jitter(width = 0.1, alpha = 0.7) + 
  geom_smooth(method = "lm", se = FALSE) +
  # O segredo: stat_cor vai herdar o 'color' e gerar um rótulo para cada estudo
  stat_cor(method = "pearson", 
           # label.x e label.y definem a posição inicial do primeiro rótulo
           label.x = 0, 
           # Se quiser que os textos não fiquem um sobre o outro, 
           # pode ser necessário ajustar a posição manualmente ou usar geom_text_repel
           show.legend = FALSE) +
  labs(x = "Incidência da doença",
       y = "Peso dos escleródios (g)", # Ajuste a unidade conforme necessário
       color = "Estudo",
       title = "Correlação entre Incidência e Peso de Escleródios") +
  theme_minimal()
 #ou
mofo |> 
  ggplot(aes(inc, scl, color = factor(study)))+
  geom_point(width=0.1)+
  geom_smooth(method= "lm", se=F)+
  stat_cor(method = "pearson", label.x = 0,  show.legend = FALSE)+
  labs(x= "Incidência da doença",
       y="Peso dos escleródios (??/??)",
       title = "Correlação entre Incidência e Peso de Escleródios")

  
#coeficiente de correlação
cor.test(mofo$inc, mofo$yld, method="pearson")    #de todos juntos (não recomendado)
cor(mofo$inc, mofo$yld, method="pearson") #dá só o valor de correlação; cor.test dá uma resposta mais completa

mofo2 <- mofo |> group_by(study) |> 
  summarise(correlacao= cor (inc,yld), method="pearson")

summary(mofo2)


