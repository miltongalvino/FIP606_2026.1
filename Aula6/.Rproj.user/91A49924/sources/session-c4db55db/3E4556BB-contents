## OUTRO LÁ

```{r}
library(readxl)
campo <- read_excel("dados_diversos.xlsx", 'fungicida_campo')

campo2 <- campo |> 
  mutate(trat=factor(TRAT),
         bloco= factor(BLOCO)) |> 
  dplyr::select(trat, bloco, PROD) |> 
  rename (prod=PROD)
```

```{r}

library(ggplot2)
campo2 |>  ggplot(aes(trat, prod))+
  geom_point(alpha=0.5)+
  ylim(1500,6000)+
  stat_summary()+
  theme_classic()+
  labs(x="Tratamento fungicida",
       y= "produtividade (kg/ha)")
```

##Modelo de ANOVA

```{r}
m_bloco <- lm(prod ~ trat + bloco, data= campo2)

m_bloco

library(DHARMa)
plot(simulateResiduals(m_bloco))

anova_m_bloco <- anova(m_bloco)

anova_m_bloco

library(emmeans)
medias_m_bloco <- emmeans(m_bloco, ~trat)
medias_m_bloco

cld(medias_m_bloco, Letters = LETTERS)
```

```{r}
library(ggplot2)
library(dplyr)
library(multcompView) # se não estiver carregado, para as letras

# 1. Salve o resultado do cld() em um objeto e remova os espaços extras das letras
letras <- cld(medias_m_bloco, Letters = LETTERS)
letras$.group <- trimws(letras$.group) # Tira os espaços em branco antes/depois das letras

# 2. Gere o gráfico sobrepondo os dados
ggplot() +
  # Adiciona os pontos brutos (jitter) da tabela campo2
  geom_jitter(data = campo2, 
              aes(x = as.factor(trat), y = prod), 
              width = 0.1, alpha = 0.4, color = "gray50") +
  
  # Adiciona as barras de erro (Intervalo de Confiança do modelo)
  geom_errorbar(data = letras, 
                aes(x = as.factor(trat), ymin = lower.CL, ymax = upper.CL), 
                width = 0.2, linewidth = 0.8, color = "black") +
  
  # Adiciona as médias estimadas (emmeans) do modelo
  geom_point(data = letras, 
             aes(x = as.factor(trat), y = emmean), 
             size = 3, color = "darkred") +
  
  # Adiciona as letras de agrupamento acima do limite superior do intervalo (upper.CL + 150)
  geom_text(data = letras, 
            aes(x = as.factor(trat), y = upper.CL + 150, label = .group), 
            fontface = "bold", size = 4.5, color = "black") +
  
  # Define limites e temas
  ylim(1500, 6000) +
  theme_classic() +
  labs(x = "Tratamento fungicida",
       y = "Produtividade")
```

