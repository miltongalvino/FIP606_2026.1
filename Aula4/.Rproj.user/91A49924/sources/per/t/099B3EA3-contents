```{r}
escala <-read_excel("dados_diversos.xlsx", "escala")

head(escala)

escala |> ggplot(aes(assessment,acuracia))+
  geom_boxplot(outlier.color = NA)+
  geom_jitter(width = 0.1)+
  ylim(0,1)

escala_wide<- escala |> 
  select(rater, assessment, acuracia) |> 
  pivot_wider(
    names_from= assessment,
    values_from= acuracia
  )

t.test(escala_wide$Unaided,
       escala_wide$Aided1,
       paired=TRUE)
  
qqnorm(escala_wide$Unaided)
qqline(escala_wide$Unaided)
shapiro.test(escala_wide$Unaided)

#	Shapiro-Wilk normality test
#data:  escala_wide$Unaided
#W = 0.77356, p-value = 0.00691         p valor menor que 0.05 quer dizer                                            que os valores não são normais.

  
qqnorm(escala_wide$Aided1)
qqline(escala_wide$Aided1)
shapiro.test(escala_wide$Aided1)


#equivalente não paramêtrico ao T-teste
wilcox.test(escala_wide$Aided1,
       escala_wide$Unaided,
       paired=TRUE)

#para fzr o teste t paramêtrico: se a variancia não for homogenea dá pra corrigir no teste T, mas se a normalidade  nao for |> tem que  usar um teste não paramêtrico

```

```{r}

micelial <- read_excel("dados_diversos.xlsx", 
                   "micelial")
count(micelial, especie)

set.seed(2)
micelial |> ggplot(aes(reorder(especie,tcm),tcm))+
  geom_boxplot(outlier.color = NA)+
  geom_jitter(width=0.2)+
  coord_flip()   #pra inverter o eixo e deixar o x mais espaçado pra escrever mais


m1 <- aov(tcm~ especie, data= micelial)

m1

anova(m1)

m2 <- lm(tcm~ especie, data= micelial)

m2

anova(m2)

#testa normalidade
hist(m2$residuals)
qqnorm(m2$residuals)
qqline(m2$residuals)
shapiro.test(m2$residuals)
#teste homocedasticidade
bartlett.test(tcm~especie, data=micelial)
```

