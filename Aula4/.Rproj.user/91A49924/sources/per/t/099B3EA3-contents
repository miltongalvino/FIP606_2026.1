```{r}
Para alterar as suas barras de erro de Desvio Padrão (SD) para Intervalo de Confiança (IC) (normalmente usamos o IC de 95%), precisamos de fazer um pequeno cálculo adicional dentro do seu summarise().

O Intervalo de Confiança é calculado usando o Erro Padrão (Desvio Padrão dividido pela raiz quadrada do número de repetições) multiplicado pelo valor t da distribuição (que nos dá os 95% de confiança).

Aqui está o seu código atualizado e comentado:

R
dados |> 
  # 1. Calcula a AUDPC por parcela (Irrigação x Repetição)
  group_by(Irrigation, rep) |> 
  summarise(audpc = AUDPC(day, severity), .groups = "drop") |> 
  
  # 2. Calcula média, N, SD e o Intervalo de Confiança (95%)
  group_by(Irrigation) |>  
  summarise(
    mean_audpc = mean(audpc),
    sd_audpc = sd(audpc),
    n_rep = n(),  # Conta quantas repetições (rep) existem por tratamento
    
    # Calcula a margem de erro do IC 95%
    # qt(0.975, df = n_rep - 1) é o valor t. 
    # (sd_audpc / sqrt(n_rep)) é o Erro Padrão.
    erro_ic = qt(0.975, df = n_rep - 1) * (sd_audpc / sqrt(n_rep)),
    
    .groups = "drop"
  ) |> 
  
  # 3. Faz o plot
  ggplot(aes(Irrigation, mean_audpc)) +
  geom_col(width = 0.5, fill = "lightgray", color = "black") + # Adicionei borda preta e cor para destacar o point
  geom_point(size = 3) +
  # Agora usamos o erro_ic para definir os limites da barra
  geom_errorbar(aes(ymin = mean_audpc - erro_ic,
                    ymax = mean_audpc + erro_ic),
                width = 0.1) +
  ylim(0, 20) +
  labs(x = "Irrigação", y = "Média da AUDPC (IC 95%)") +
  theme_get()
```

