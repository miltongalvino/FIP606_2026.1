k

#GLM com a família e função de ligação   (MAIS ELEGANTEEEEEEE MELHOR PARA ARTIGOSSS)

m4 <- glm(count~spray, 
          family=poisson, 
          data=insetos)
m4

plot(simulateResiduals(m1))
plot(simulateResiduals(m4))

anova(m4)

df3 <- cld(emmeans(m4, ~spray, type = "response"), Letters=letters)

df3 |> 
  ggplot(aes(x=reorder (spray, -rate),y=rate, label=.group))+
  geom_point()+
  geom_errorbar(aes(ymin= asymp.LCL,
                    ymax= asymp.UCL),
                width=0.1)+
  geom_text(aes(y=asymp.UCL),
             vjust = -0.5,
             size= 4)+
  ylim(00,25)+ 
  theme_classic()+
  coord_flip()

```
