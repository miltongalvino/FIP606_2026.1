Dados discretos a gente assume normalidade dados contínuos não

```{r}
insetos <- InsectSprays                         #atribuir ao objeto "insetos" o dataframe "InsectSprays"
library(tidyverse)                              
library(ggplot2)

insetos |>  ggplot(aes(spray, count))+      #A partir do objeto insetos formar um gráfico relacionando (spray e contagem)
  geom_boxplot(outlier.colour = NA)+        #Adicionar o box plot sem apresentar os outliers
  geom_jitter(width = 0.1)                  #Adicionar pontos de forma espalhadas com espaçamento de 0.1


```

Falta de variancia homogenea é pior que falta de normalidade

```{r}
m1 <- lm(count~spray, insetos) m1                #a

summary (m1) anova(m1)

hist(m1$residuals)

shapiro.test(m1$residuals)

bartlett.test(count~spray, data=insetos)



install.packages("performance") 
library(performance)

check_normality(m1)
check_heteroscedasticity(m1)

kruskal.test(count~spray, insetos)


install.packages("qqplotr")
library(qqplotr)
library(see)
library(DHARMa)

plot(simulateResiduals(m1))
```

```{r}
library(tidyverse)


m2 <-  lm(sqrt(count)~spray, data=insetos)
m2

anova(m2)
shapiro.test(m2$residuals)
bartlet.test(m2$residuals)


insetos2 |>  ggplot(aes(spray, count2))+
  geom_boxplot(outlier.colour = NA)+
  geom_jitter(width = 0.1)

library(DHARMa)
library(performance)
check_normality(m2)
check_heteroscedasticity(m2)

plot(simulateResiduals(m2))

library(emmeans)
medias <- emmeans(m1, ~spray)
medias

medias2 <- emmeans(m2, ~spray)
medias2

medias3 <- emmeans(m2, ~spray, type = "response")
medias3

library(multcomp)

cld(medias, Letters= letters)
cld(medias2,Letters= letters)
cld(medias3, Letters= letters)

```

```{r}
library(agricolae)

