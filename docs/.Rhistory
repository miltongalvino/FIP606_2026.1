library(tidyverse)
library(tidyverse)
insetos <- InsectSprays
glimpse(insetos)
head(insetos)
glimpse(insetos)
head(insetos)
insetos |>
ggplot(aes(x = spray, y = count)) +
geom_boxplot(outlier.colour = NA) +
geom_jitter(width = 0.1, alpha = 0.7) +
theme_classic() +
labs(
x = "Tratamento (spray)",
y = "Número de insetos sobreviventes"
)
insetos |>
ggplot(aes(x = spray, y = count)) +
geom_boxplot(outlier.colour = NA) +
geom_jitter(width = 0.1, alpha = 0.7) +
theme_classic() +
labs(
x = "Tratamento (spray)",
y = "Número de insetos sobreviventes"
)
insetos |>
group_by(spray) |>
summarise(
n = n(),
media = mean(count),
desvio_padrao = sd(count),
erro_padrao = sd(count) / sqrt(n)
)
