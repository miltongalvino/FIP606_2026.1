m3 <- glm(count ~ spray,        #atribuir ao objeto m3 a função de modelo linear generalizado, relacionando contagem e spray
family = poisson, #família poisson
data = insetos) #dados de insetos
summary(m3)
df3 <- cld(
emmeans(m3, ~ spray, type = "response"),
Letters = LETTERS
)
df3
df3 |>
ggplot(aes(x = reorder(spray, -rate), y = rate, label = .group)) +
geom_point() +
geom_errorbar(aes(ymin = asymp.LCL, ymax = asymp.UCL), width = 0.1) +
geom_text(aes(y = asymp.UCL), vjust = -0.5, size = 4) +
theme_classic() +
labs(
x = "Inseticida",
y = "Insetos vivos (contagem esperada)"
) +
coord_flip()
sessionInfo()
check_normality(m1)               #checar normalidade
check_heteroscedasticity(m1)      #checar heterocedasticidade
library(performance)       #Carregar pacote performance
check_normality(m1)               #checar normalidade
check_heteroscedasticity(m1)      #checar heterocedasticidade
plot(simulateResiduals(m1))
