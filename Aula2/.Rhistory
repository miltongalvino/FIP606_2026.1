software <- gsheet2tbl ("https://docs.google.com/spreadsheets/d/1bq2N19DcZdtax2fQW9OHSGMR0X2__Z9T/edit?gid=373270992#gid=373270992")
View(software)
library("tidyverse")
glimpse(software)
dados <- software
dados_longos <- dados |>
pivot_longer(
cols = c(Assess, LeafDoctor, ImageJ),
names_to = "software",
values_to = "severidade")
dados_longos
View(dados_longos)
glimpse(software)
View(dados)
#Fazer gráfico
library(ggplot2)
dados_longos |>
ggplot(aes(software,  severidade,
color= software))+
geom_boxplot(outlier.colour = )+
geom_jitter(width = 0.1, alpha = 0.3)+
theme_minimal()+
theme(legend.position = "none")+
facet_wrap(~ crop)
dados_longos |>    #utilizando o objeto "dados longos",realizar a seguinte função:
ggplot(aes(software,  severidade,   #Formar gráfico associando o tipo software e o  valor de severidade
color= software))+ #adicionar cores distintas as variáveis software
geom_boxplot(outlier.colour = )+ #Adicionar um boxplot
geom_jitter(width = 0.1, alpha = 0.3)+ #Separar os pontos que se sobrepõem
theme_minimal()+ #Adicionar o tema mínimo
facet_wrap(~ crop)
