# Gráfico 2: Gráfico de dispersão com jitter
# O 'geom_jitter' espalha levemente os pontos no eixo horizontal para
# evitar que eles fiquem sobrepostos, facilitando a visualização geral.
grafico_jitter <- ggplot(dados, aes(x = tratamento, y = severidade)) +
geom_point() +
geom_jitter(width = 0.2)
print(grafico_jitter)
